style sell_text:
    min_width 250
    text_align 0.5


screen sell():
    style_prefix "sell"
    add "gui/frame.webp" zoom 1.5 align (0.5,0.5)
    text "可出售" align (0.1,0.1)
    text "待出售" align (0.7,0.1)

    frame align (0.1,0.5):
        background None

        xsize 400
        ysize 600
        has viewport yalign 0.2
        draggable True
        mousewheel True
        arrowkeys True
        scrollbars "vertical"

        align (0.5,0.5)
        vbox:
            for i in kufang:
                $ tempjiage = sell_jiage(i)
                hbox spacing 30:
                    text "[i.name] [tempjiage]两"
                    textbutton "{size=25}    出售":
                        action Function(sell_out,i),SetVariable("itemsjiage",itemsjiage+tempjiage)
    frame align (0.7,0.5):
        background None
        xsize 400
        ysize 600

        has viewport yalign 0.2
        draggable True
        mousewheel True
        arrowkeys True
        scrollbars "vertical"
        xsize 600
        ysize 400
        align (0.5,0.5)
        vbox:
            for i in sell_list:
                $ tempjiage = sell_jiage(i)
                hbox spacing 30:
                    text "[i.name] [tempjiage]两"
                    textbutton "{size=25}    取消":
                        action Function(sell_back,i),SetVariable("itemsjiage",itemsjiage-tempjiage)
    vbox align (0.5,0.8):
        text "总计售出所得：[itemsjiage]两"
        textbutton "确认交易" action Function(sell_finish),SetVariable("money",money + itemsjiage),SetVariable("ygg_like",ygg_like + itemsjiage*0.005),Hide("sell"),Return()


