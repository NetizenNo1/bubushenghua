default dance01 = Item(name="{color=#008000}《春归》{/color}",level=0,leibie="舞谱",fengge="——",jieshao="纸张整齐干净，细看便知乃新抄的，记得取时架上还有不少一样的。面上写道：雪化之时，万物醒，寒风渐去。春雷一鸣，春雨下，檐下绿芽生，苔沿石而发。待人初醒时，绿丛中零星几许红，细看不过花芽待放。",jiage=0,wcd=0)
default dance02 = Item(name="{color=#008000}《引蝶》{/color}",level=0,leibie="舞谱",fengge="——",jieshao="纸张整洁，被自个在一些须注意处留了记号，此谱还算常见。花为一舞，蝶为一舞，两者相合才为引蝶。若自身为花，便时而两手做蝶。需带一把折扇，舞时一举一动皆撩人心弦，优雅华丽，将女人的美表达得可谓淋漓尽致，像极了蝶也像极了花。",jiage=0,wcd=0)
default dance03 = Item(name="{color=#0040FF}《剑器行》{/color}",level=1,leibie="舞谱",fengge="——",jieshao="纸张有些许受潮，并无大碍，书脊上的线也是取时换的，用起来也更为放心。需与剑相配，方才能为剑器行，属剑舞。大方、有气场、势最猛，以男子练剑时的动作为感所谱。配以鼓声、萧声可谓画龙点睛，两者皆可造出不同之效。",jiage=0,wcd=0)
default dance04 = Item(name="{color=#0040FF}《胡旋》{/color}",level=1,leibie="舞谱",fengge="——",jieshao="缺了一些书角，但书面却有一轻纱覆盖，似是保护。此舞来自西域，奔腾欢快，多旋转踢踏，长袖一摆，旋舞起来时，身如飘雪飞如。与多种鼓乐相配，可营造出西域女子之风，风格最为特别。",jiage=0,wcd=0)
default dance05 = Item(name="{color=#EE00EE}《塞外雪》{/color}",level=2,leibie="舞谱",fengge="——",jieshao="翻阅之痕较多，谱面有一画，画有一头戴轻纱异域女子，在雪中对天做拜佛之势。乃呈现塞外雪景之舞，却舞步轻快，且只能独舞。若懂的人细细品味，可感到一丝丝孤独的悲凉。",jiage=0,wcd=0)
default dance06 = Item(name="{color=#EE00EE}《贵妃醉酒{/color}》",level=2,leibie="舞谱",fengge="——",jieshao="不算老旧，但也有些尘扑。又名《百花亭》，以同名京剧为感所创，与唱词、曲调一同，可感宠妃由期盼到失望，再到怨恨的复杂感上，最难把控。若与戏腔相合，可谓锦上添花。",jiage=0,wcd=0)
default dance07 = Item(name="{color=#FF3030}《掌上舞》{/color}",level=3,leibie="舞谱",fengge="——",jieshao="纸页泛黄，取翻时需留心。此舞最为轻盈，若稍胖些便难舞成。据说能现此舞者，风稍大些便易吹走。又闻双掌便能将其托起，而人仍可在掌上起舞。",jiage=0,wcd=0)
default dance08 = Item(name="{color=#FF3030}《惊鸿》{/color}",level=3,leibie="舞谱",fengge="——",jieshao="纸张有轻微烧灼之痕，需轻拿轻放，稍有不妥恐会毁于一旦，其中卷首题字道：唯愁捉不住，飞去逐惊鸿。舞姿如鸿雁般在空中展翅翱翔，动作轻盈、飘逸、柔美，可一人演绎独雁、对雁、群雁。能让观者宛若眼前真有鸿雁。因此舞之难，所能跳成之人寥寥无几。",jiage=0,wcd=0)
default dance09 = Item(name="{color=#F7AB00}《明月》{/color}",level=4,leibie="舞谱",fengge="——",jieshao="举杯邀明月,对影成三人。",jiage=0,wcd=0)

default music01 = Item(name="{color=#008000}《梁祝》{/color}",level=0,leibie="曲谱",fengge="——",jieshao="有些折痕，但纸张保存完好，属常见曲谱。此曲可谓家喻户晓，乃源于民间四大爱情故事之一，分“草桥结拜”、“英台抗婚”、“坟前化蝶”三章。越剧曲调，曲因乐章不同可有多种奏法，变化多端，唯一不变的，是曲中的深情。",jiage=0,wcd=0)
default music02 = Item(name="{color=#008000}《采莲》{/color}",level=0,leibie="曲谱",fengge="——",jieshao="纸张新颖，却画有荷塘，且卷首写道：江南可采莲，莲叶何田田。江南风味，温柔恬静。此曲本以为是映那荷塘美景，夏日柔情，只道细细品味，用心专研，才方能得知此非景，而是一羞涩女子。配与丝竹，可更上一层楼。",jiage=0,wcd=0)
default music03 = Item(name="{color=#0040FF}《山鬼》{/color}",level=1,leibie="曲谱",fengge="——",jieshao="纸张有些泛黄，还有一些书虫啃食之痕，卷首写道：采三秀兮于山间，石磊磊兮葛蔓蔓。祀神乐歌，较为庄重，半写神半写景，两者相辅相成，缺一不可，相互交错。此曲调瑰丽却离奇，感情复杂，似深情却又伴着哀怨。",jiage=0,wcd=0)
default music04 = Item(name="{color=#0040FF}《湘女》{/color}",level=1,leibie="曲谱",fengge="——",jieshao="纸微皱，乃泡水晒干遗留之痕，因此纸脆，翻页需小心。湘水风情，若是湘女奏此曲，总能带出一些旁人不及的韵味。曲写秋，而秋中更有女，此女自湘水，湘女最多情。",jiage=0,wcd=0)
default music05 = Item(name="{color=#EE00EE}《求凰》{/color}",level=2,leibie="曲谱",fengge="——",jieshao="纸有缺失，被人寻回粘上，才得以完整，乃名曲之一，与《凤兮》为对。言浅意深，音节流亮，热烈奔放而又深挚缠绵，融楚辞骚体的旖旎绵邈和民歌的清新明快于一炉。",jiage=0,wcd=0)
default music06 = Item(name="{color=#EE00EE}《凤兮》{/color}",level=2,leibie="曲谱",fengge="——",jieshao="与其他曲谱比起，纸似本就偏黄些许，乃名曲之一，与《求凰》为对。意深，音节多重音，大气庄重却不失情味，融多重奏法，若可有丝竹与一旁同时奏《凤兮》，可谓有凤来仪。",jiage=0,wcd=0)
default music07 = Item(name="{color=#FF3030}《羲和》{/color}",level=3,leibie="曲谱",fengge="——",jieshao="纸有很多翻阅之痕，且此谱珍贵，便有多一层书页保护。《山海经·大荒南经》中记载：东南海之外，甘水之间，有羲和之国。有女子名曰羲和，方日浴于甘渊。此曲优雅瑰丽，细腻悠长，似神所拥之物，若要奏出其中韵味，还有其奏法之繁，很是为难人。",jiage=0,wcd=0)
default music08 = Item(name="{color=#FF3030}《无绝》{/color}",level=3,leibie="曲谱",fengge="——",jieshao="纸张有各种划痕，翻页若是不谨慎，很是容易变为碎片。无绝山位于长安以东，那儿景色最为出名，山路也很是崎岖。常见的说景之曲，却曲为最长，从天至地，日出至落，由南到北，繁星走兽，一曲皆有，犹如一有变化的画卷一般。因曲长，奏法自然繁琐，难度之大乃能奏出味道之人屈指可数。",jiage=0,wcd=0)
default music09 = Item(name="{color=#F7AB00}《锦瑟》{/color}",level=4,leibie="曲谱",fengge="——",jieshao="锦瑟无端五十弦，一弦一柱思华年。 ",jiage=0,wcd=0)


