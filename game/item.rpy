    def sell_out(self):
        global kufang
        global sell_list
        kufang.remove(self)
        sell_list.append(self)

    def sell_back(self):
        global kufang
        global sell_list
        sell_list.remove(self)
        kufang.append(self)

    def sell_finish():
        global kemai
        global sell_list
        for i in sell_list:
            kemai.append(i)


    def buy_finish():
        global kufang
        global kemai
        global buy_list
        for i in buy_list:
            kufang.append(i)


    def buy_in(self):
        global kufang
        global buy_list
        global kemai
        buy_list.append(self)
        kemai.remove(self)

    def buy_back(self):
        global kufang
        global buy_list
        global kemai
        kemai.insert(0,self)
        buy_list.remove(self)

